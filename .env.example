# MongoDB connection string for Render or local development
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# Port Render will override this automatically
PORT=5000

# Optional: restrict CORS to your Flutter web origin in production
CLIENT_ORIGIN=http://localhost:3000

# For Render or production, set NODE_ENV=production
NODE_ENV=development
